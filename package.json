{
  "name": "chmarl-datav",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "description": "CH-MARL maritime logistics geospatial visualization platform.",
  "scripts": {
    "dev": "node scripts/dev-single-port.mjs",
    "dev:single": "node scripts/dev-single-port.mjs",
    "dev:proxy": "node scripts/dev-with-proxy.mjs",
    "dev:vite": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:codespaces": "node scripts/dev-single-port.mjs",
    "proxy": "node server/vessel-feed-proxy/index.mjs",
    "diagnose": "node scripts/portal-diagnostics.mjs",
    "diagnose:ais": "node scripts/aisstream-diagnostics.mjs",
    "diagnose:env": "node scripts/check-portal-env.mjs",
    "diagnose:ports": "node scripts/port-forward-diagnostics.mjs",
    "diagnose:freshness": "node scripts/check-provider-freshness.mjs",
    "diagnose:contracts": "node scripts/check-api-contracts.mjs",
    "diagnose:git": "node scripts/check-git-working-tree.mjs",
    "diagnose:locks": "node scripts/check-lockfile-drift.mjs",
    "wait:portal": "node scripts/wait-for-portal.mjs",
    "wait:vessels": "node scripts/wait-for-vessels.mjs",
    "smoke": "node scripts/portal-smoke-test.mjs",
    "watch:vessels": "node scripts/watch-vessel-feed.mjs",
    "snapshot": "node scripts/export-runtime-snapshot.mjs",
    "cache:inspect": "node scripts/inspect-runtime-cache.mjs",
    "env:init": "node scripts/create-env-local-template.mjs",
    "validate:ports": "node scripts/validate-port-feed.mjs",
    "validate:chmarl": "node scripts/validate-chmarl-feed.mjs",
    "urls": "node scripts/print-runtime-urls.mjs",
    "cache:clear": "node scripts/clear-runtime-cache.mjs",
    "verify:dist": "node scripts/verify-build-artifacts.mjs",
    "build": "tsc -b && vite build",
    "build:prod": "VITE_VESSEL_DATA_URL=/api/vessels pnpm build",
    "start": "node scripts/start-prod.mjs",
    "start:prod": "node scripts/start-prod.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.2",
    "echarts": "^6.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.183.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^5.4.19"
  }
}
