# Copy this file to .env.local for local/Codespaces development.
# .env.local is gitignored, so API keys and tokens stay outside the repository.

# Frontend: same-origin backend routes.
VITE_VESSEL_DATA_URL=/api/vessels
VITE_PROXY_TARGET=http://localhost:8787
VITE_CHMARL_EXPERIMENT_URL=/api/chmarl/episode
VITE_PORT_EVENTS_URL=/api/port-events
VITE_PORT_EVENTS_DEMO_ENABLED=false
VITE_WEATHER_URL=/api/weather
VITE_WEATHER_CACHE_MS=600000
VITE_WEATHER_TIMEOUT_MS=3000
VITE_ALLOW_SAMPLE_DATA=false
VITE_ALLOW_SAMPLE_CHMARL=false
# All tracking rows remain visible; EcoFair is scoped independently on the backend.
VITE_REQUIRE_OPERATIONAL_REGION=false

# Runtime persistence. Render mounts this at /var/data; local development uses .runtime.
RUNTIME_DATA_DIR=.runtime

# Optional upstream vessel API merged with AIS and fixed/manual rows.
UPSTREAM_VESSEL_DATA_URL=
UPSTREAM_VESSEL_DATA_TOKEN=

# Fixed/manual vessel rows. These are included in tracking and are used by
# EcoFair only when they fall inside the monitored-port calculation radius.
FIXED_VESSEL_DATA_FILE=.runtime/manual-vessels.json
FIXED_VESSEL_DATA_FILE_ENABLED=true
FIXED_VESSEL_DATA_URL=
FIXED_VESSEL_DATA_TOKEN=
FIXED_VESSEL_INGEST_TOKEN=

# AISStream tracking. The display feed can be global while EcoFair calculations
# remain restricted to monitored ports.
AISSTREAM_API_KEY=
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_GLOBAL_TRACKING_ENABLED=true
AISSTREAM_TRACKING_BBOX=-90,-180;90,180
# Regional values remain available when global tracking is disabled.
AISSTREAM_BBOX=11,32;31,56
AISSTREAM_APPEND_SAUDI_PORT_BBOXES=true
# Position messages only reduce bandwidth and avoid non-positional payloads.
AISSTREAM_FILTER_TYPES=PositionReport,StandardClassBPositionReport,ExtendedClassBPositionReport
AISSTREAM_MAX_VESSELS=5000
AISSTREAM_MAX_AGE_MS=21600000
AISSTREAM_TRAIL_POINTS=12
AISSTREAM_CACHE_ENABLED=true
AISSTREAM_CACHE_FILE=
AISSTREAM_CACHE_FLUSH_MS=30000

# EcoFair-CH-MARL operational scope. The map/API can show every tracked vessel,
# while fuel, CO2, fairness, queue, reward, and constraint calculations use only
# vessels within this radius of Jeddah, King Abdullah Port, Yanbu, Jizan,
# Dammam, Jebel Ali, or Suez.
ECOFAIR_OPERATIONAL_RADIUS_NM=120
ECOFAIR_EMISSION_BUDGET_TONNES_PER_DAY=0
ECOFAIR_BUDGET_TONNES_PER_VESSEL_PER_DAY=60
ECOFAIR_GAMMA_EMIS=10
ECOFAIR_GAMMA_FAIR=5
ECOFAIR_LAMBDA_LR=0.05
ECOFAIR_GINI_LIMIT=0.35
ECOFAIR_MINMAX_LIMIT=0.4
ECOFAIR_BERTH_RADIUS_NM=5
ECOFAIR_ANCHORAGE_RADIUS_NM=20
ECOFAIR_TICK_MS=60000
ECOFAIR_STATE_FILE=
ECOFAIR_PORT_CAPACITY=

# Runtime CH-MARL experiment feed and ingestion endpoint.
CHMARL_RUNTIME_ENABLED=true
CHMARL_HISTORY_LIMIT=96
CHMARL_HISTORY_MIN_INTERVAL_MS=60000
CHMARL_EXPERIMENT_FILE=.runtime/chmarl-episode.json
CHMARL_EXPERIMENT_URL=
CHMARL_EXPERIMENT_TOKEN=
CHMARL_FILE_ENABLED=false
CHMARL_INGEST_TOKEN=

# Runtime port event / berth / queue provider.
PORT_EVENTS_FILE=.runtime/port-events.json
PORT_EVENTS_FILE_ENABLED=false
PORT_EVENTS_URL=
PORT_EVENTS_TOKEN=

# Optional weather provider/file; Open-Meteo is used when these are empty.
WEATHER_URL=
WEATHER_TOKEN=
WEATHER_FILE=.runtime/weather.json
WEATHER_FILE_ENABLED=false
WEATHER_CACHE_MS=600000
WEATHER_TIMEOUT_MS=4000

PORT=8787
VITE_PORT=5173
VITE_MIRROR_PORT=3000
