# Copy this file to .env.local for local/Codespaces development.
# .env.local is gitignored, so your API key stays outside the repository.

# Frontend: use the same-origin Vite proxy path in Codespaces/browser development.
# Vite forwards /api/vessels to the backend proxy at VITE_PROXY_TARGET.
VITE_VESSEL_DATA_URL=/api/vessels
VITE_PROXY_TARGET=http://localhost:8787
VITE_CHMARL_EXPERIMENT_URL=/api/chmarl/episode

# Backend proxy: optional generic upstream JSON endpoint.
UPSTREAM_VESSEL_DATA_URL=
UPSTREAM_VESSEL_DATA_TOKEN=

# Backend proxy: optional AISStream live mode.
# Keep this key server-side only. Do not commit a real key.
AISSTREAM_API_KEY=
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
# Bounding box format: lat1,lon1;lat2,lon2. Separate multiple boxes with |.
# Default below roughly covers Red Sea + Arabian Gulf focus used by the dashboard.
AISSTREAM_BBOX=11,32;31,56
AISSTREAM_MAX_VESSELS=250
AISSTREAM_TRAIL_POINTS=24
AISSTREAM_FILTER_TYPES=PositionReport,StandardClassBPositionReport,ExtendedClassBPositionReport

# AIS cache persistence. Keeps recent vessels/trails across service restarts.
AISSTREAM_CACHE_ENABLED=true
AISSTREAM_CACHE_FILE=.runtime/ais-cache.json
AISSTREAM_CACHE_FLUSH_MS=15000

# Runtime CH-MARL experiment feed.
# Use CHMARL_EXPERIMENT_FILE for a local exported episode JSON, or CHMARL_EXPERIMENT_URL for a remote service.
CHMARL_EXPERIMENT_FILE=.runtime/chmarl_episode.json
CHMARL_EXPERIMENT_URL=
CHMARL_EXPERIMENT_TOKEN=

# Optional dashboard/proxy ports.
PORT=8787
VITE_PORT=5173
