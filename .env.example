# Copy this file to .env.local for local/Codespaces development.
# .env.local is gitignored, so your API key stays outside the repository.

# Frontend: use same-origin proxy paths in Codespaces/browser development.
VITE_VESSEL_DATA_URL=/api/vessels
VITE_PROXY_TARGET=http://localhost:8787
VITE_CHMARL_EXPERIMENT_URL=/api/chmarl/episode
VITE_PORT_EVENTS_URL=/api/port-events
# Port events are now derived from live AIS geofences by the backend.
# Demo events are opt-in only (set to true for UI demos without a backend).
VITE_PORT_EVENTS_DEMO_ENABLED=false
# Weather now routes through the backend by default.
VITE_WEATHER_URL=/api/weather
VITE_WEATHER_CACHE_MS=600000
VITE_WEATHER_TIMEOUT_MS=3000

# Samples are off by default. Turn on only for local UI demos.
VITE_ALLOW_SAMPLE_DATA=false
VITE_ALLOW_SAMPLE_CHMARL=false
# Production dashboard guard: flag out-of-region AIS rows as non-operational evidence.
# Set false only when intentionally validating UI with non-Saudi test boxes.
VITE_REQUIRE_OPERATIONAL_REGION=true

# Optional generic upstream JSON endpoint for vessel rows.
UPSTREAM_VESSEL_DATA_URL=
UPSTREAM_VESSEL_DATA_TOKEN=

# Manual/fixed vessel rows are merged with AIS/API rows and then fed into
# EcoFair-CH-MARL. Use this for known Saudi vessels/port-call rows while AIS
# coverage is incomplete. The file can also be updated by POST /api/vessels/fixed.
FIXED_VESSELS_FILE_ENABLED=true
FIXED_VESSELS_FILE=.runtime/fixed_vessels.json
FIXED_VESSELS_JSON=

# AISStream live mode. Keep the real key server-side only.
AISSTREAM_API_KEY=
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
# In production, keep this true so accidental test boxes cannot replace the Saudi/Red Sea feed.
AISSTREAM_FORCE_REGIONAL_BBOX=true
# Broad regional Red Sea/Gulf box.
AISSTREAM_BBOX=11,32;31,56
# Keep true so the runtime also subscribes to Saudi port approach boxes
# for Jeddah, King Abdullah Port, Yanbu, Jizan, Dammam, Jebel Ali, and Suez.
AISSTREAM_APPEND_SAUDI_PORT_BBOXES=true
# Legacy flag retained for compatibility. Do not use it to replace the regional box.
AISSTREAM_USE_SAUDI_PORT_BBOXES=false
AISSTREAM_MAX_VESSELS=750
AISSTREAM_MAX_AGE_MS=21600000
AISSTREAM_TRAIL_POINTS=24
# Empty means do not filter message types. This avoids filtering out valid provider messages.
AISSTREAM_FILTER_TYPES=

# AIS cache persistence.
AISSTREAM_CACHE_ENABLED=true
# Leave empty in production to use BBOX-scoped runtime cache files.
AISSTREAM_CACHE_FILE=
AISSTREAM_CACHE_FLUSH_MS=15000
RUNTIME_CACHE_SCOPE=bbox

# EcoFair-CH-MARL live measurement runtime (paper measures on real AIS/API/manual rows).
# See docs/ECOFAIR_MEASURES.md and server/vessel-feed-proxy/ecofair.mjs.
# Budget mode: 0 (default) scales with the tracked fleet
# (ECOFAIR_BUDGET_TONNES_PER_VESSEL_PER_DAY x active vessels). Set a positive
# fixed value only for a known, bounded fleet.
ECOFAIR_EMISSION_BUDGET_TONNES_PER_DAY=0
ECOFAIR_BUDGET_TONNES_PER_VESSEL_PER_DAY=60
ECOFAIR_GAMMA_EMIS=10
ECOFAIR_GAMMA_FAIR=5
ECOFAIR_LAMBDA_LR=0.05
ECOFAIR_GINI_LIMIT=0.35
ECOFAIR_MINMAX_LIMIT=0.4
ECOFAIR_BERTH_RADIUS_NM=5
ECOFAIR_ANCHORAGE_RADIUS_NM=20
ECOFAIR_TICK_MS=60000
ECOFAIR_STATE_FILE=
# Optional JSON map of reference berth capacities, e.g. {"Jeddah": 24}
ECOFAIR_PORT_CAPACITY=

# Runtime CH-MARL experiment feed and ingestion endpoint.
CHMARL_EXPERIMENT_FILE=.runtime/chmarl_episode.json
CHMARL_EXPERIMENT_URL=
CHMARL_EXPERIMENT_TOKEN=
# Optional bearer token required by POST /api/chmarl/ingest and /api/vessels/fixed when set.
CHMARL_INGEST_TOKEN=

# Runtime port-event / berth / queue feed.
PORT_EVENTS_FILE=.runtime/port_events.json
PORT_EVENTS_FILE_ENABLED=false
PORT_EVENTS_URL=

# Optional runtime weather provider/file. If empty, backend uses Open-Meteo Marine.
WEATHER_URL=
WEATHER_TOKEN=
WEATHER_FILE=.runtime/weather.json
WEATHER_FILE_ENABLED=false

# Optional dashboard/proxy ports.
PORT=8787
VITE_PORT=5173
